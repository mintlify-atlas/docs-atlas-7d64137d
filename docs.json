{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Cypress GitHub Action",
  "theme": "aspen",
  "colors": {
    "primary": "#1c1c2c",
    "light": "#59ce99",
    "dark": "#34685d"
  },
  "favicon": "https://media.brand.dev/a1351356-7fef-4c6b-8b56-3611941da4f0.png",
  "logo": {
    "light": "https://media.brand.dev/34785661-d184-4478-ac63-7cbe08751354.svg",
    "dark": "https://media.brand.dev/34785661-d184-4478-ac63-7cbe08751354.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/cypress-io/github-action"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cypress-io/github-action"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "action-version"
            ]
          },
          {
            "group": "Testing",
            "pages": [
              "testing/e2e",
              "testing/component",
              "testing/browsers",
              "testing/specs-and-config"
            ]
          },
          {
            "group": "Workflow Setup",
            "pages": [
              "workflow/server-and-build",
              "workflow/installation",
              "workflow/caching",
              "workflow/working-directory"
            ]
          },
          {
            "group": "Cypress Cloud",
            "pages": [
              "cloud/recording",
              "cloud/parallel",
              "cloud/advanced-cloud"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/custom-commands",
              "advanced/package-managers",
              "advanced/debugging",
              "advanced/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Action Reference",
            "pages": [
              "reference/inputs",
              "reference/outputs",
              "reference/cli-migration"
            ]
          }
        ]
      }
    ]
  }
}
